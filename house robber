class Solution(object):
    def rob(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        rob_prev2, rob_prev1 = 0, 0
        for n in nums:
            temp = max(n + rob_prev2, rob_prev1)
            rob_prev2 = rob_prev1
            rob_prev1 = temp
        return rob_prev1
